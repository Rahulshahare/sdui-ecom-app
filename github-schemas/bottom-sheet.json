{
  "type": "scrollView",
  "style": { "flex": 1, "backgroundColor": "#fff" },
  "children": [
    {
      "type": "container",
      "style": { "padding": 16 },
      "children": [
        {
          "type": "text",
          "content": "Product Details",
          "style": { "fontSize": 24, "fontWeight": "bold", "marginBottom": 16 }
        },
        {
          "type": "image",
          "source": "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=600",
          "style": { "width": "100%", "height": 300, "borderRadius": 12, "marginBottom": 16 }
        },
        {
          "type": "text",
          "content": "$79.99",
          "style": { "fontSize": 28, "fontWeight": "bold", "color": "#007AFF", "marginBottom": 8 }
        },
        {
          "type": "row",
          "style": { "gap": 12, "marginBottom": 16 },
          "children": [
            {
              "type": "button",
              "text": "Select Size",
              "style": { "backgroundColor": "#f0f0f0", "flex": 1 },
              "textStyle": { "color": "#333" },
              "action": { "type": "custom", "handler": "openBottomSheet" }
            },
            {
              "type": "button",
              "text": "Add to Cart",
              "style": { "backgroundColor": "#007AFF", "flex": 1 },
              "action": { "type": "custom", "handler": "addToCart" }
            }
          ]
        },
        {
          "type": "button",
          "text": "Delete from Wishlist",
          "style": { "backgroundColor": "#FF3B30" },
          "action": { "type": "custom", "handler": "openModal" }
        }
      ]
    },
    
    {
      "type": "bottomSheet",
      "props": {
        "visible": false,
        "snapPoints": [0.4, 0.7],
        "initialSnap": 0,
        "backdropDismiss": true,
        "dragIndicator": true
      },
      "children": [
        {
          "type": "text",
          "content": "Select Size",
          "style": { "fontSize": 20, "fontWeight": "bold", "marginBottom": 16 }
        },
        {
          "type": "row",
          "style": { "flexWrap": "wrap", "gap": 12 },
          "children": [
            { "type": "badge", "text": "S", "style": { "paddingHorizontal": 24, "paddingVertical": 12 } },
            { "type": "badge", "text": "M", "style": { "backgroundColor": "#007AFF", "paddingHorizontal": 24, "paddingVertical": 12 } },
            { "type": "badge", "text": "L", "style": { "paddingHorizontal": 24, "paddingVertical": 12 } },
            { "type": "badge", "text": "XL", "style": { "paddingHorizontal": 24, "paddingVertical": 12 } }
          ]
        },
        {
          "type": "spacer",
          "props": { "size": 20 }
        },
        {
          "type": "button",
          "text": "Done",
          "action": { "type": "custom", "handler": "closeBottomSheet" }
        }
      ]
    },
    
    {
      "type": "modal",
      "props": {
        "visible": false,
        "title": "Confirm Delete",
        "backdropDismiss": true,
        "animationType": "fade"
      },
      "children": [
        {
          "type": "text",
          "content": "Are you sure you want to remove this item from your wishlist?",
          "style": { "fontSize": 15, "color": "#666", "textAlign": "center", "marginBottom": 20 }
        },
        {
          "type": "row",
          "style": { "gap": 12 },
          "children": [
            {
              "type": "button",
              "text": "Cancel",
              "style": { "backgroundColor": "#f0f0f0", "flex": 1 },
              "textStyle": { "color": "#333" },
              "action": { "type": "custom", "handler": "closeModal" }
            },
            {
              "type": "button",
              "text": "Delete",
              "style": { "backgroundColor": "#FF3B30", "flex": 1 },
              "action": { "type": "custom", "handler": "confirmDelete" }
            }
          ]
        }
      ]
    }
  ]
}