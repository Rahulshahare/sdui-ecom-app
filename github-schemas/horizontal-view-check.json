{
  "type": "scrollView",
  "style": { "flex": 1, "backgroundColor": "#fff" },
  "children": [
    {
      "type": "horizontalScrollView",
      "style": { "height": 200, "marginTop":20 },
      "props": { "pagingEnabled": true },
      "children": [
        {   "type": "image", 
            "source": "https://images.unsplash.com/vector-1759149046478-4e81e5ea0d9c?q=80&w=500", 
            "style": { "width": 300, "height": 200,"marginRight": 12, "borderRadius": 12} 
        },
        {   "type": "image", 
            "source": "https://plus.unsplash.com/premium_vector-1722093079219-48778ce769cd?q=70&w=400", 
            "style": { "width": 300, "height": 200, "marginRight": 12, "borderRadius": 12 } 
        },
        {   "type": "image", 
            "source": "https://plus.unsplash.com/premium_vector-1722093079219-48778ce769cd?q=70&w=400", 
            "style": { "width": 300, "height": 200, "marginRight": 12, "borderRadius": 12 } 
        },
        {   "type": "image", 
            "source": "https://plus.unsplash.com/premium_vector-1722093079219-48778ce769cd?q=70&w=400", 
            "style": { "width": 300, "height": 200, "marginRight": 12, "borderRadius": 12 } 
        }
      ]
    },
    {
      "type": "text",
      "content": "Very long product name that truncates after two lines...",
      "props": { "numberOfLines": 2, "ellipsizeMode": "tail" }
    },
    {
      "type": "button",
      "text": "Add to Cart",
      "icon": "🛒",
      "props": { "loading": false, "disabled": false },
      "action": { "type": "custom", "handler": "addToCart" },
      "style":{"marginTop":10,"marginBottom":50}
    },
    {
        "type": "input",
        "placeholder": "Email",
        "props": {
            "keyboardType": "email-address",
            "required": true,
            "errorText": "Valid email required",
            "helperText": "For order updates"
        }
    }
  ]
}